# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Models
SUPERVISOR_MODEL=claude-opus-4-7
WORKER_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-opus-4-7
EMBEDDING_MODEL=text-embedding-005

# Provider mode: "mock" (always for demo) or "live" (stub, never enabled)
PROVIDER_MODE=mock

# Notification
SENDGRID_API_KEY=
NOTIFY_FROM_EMAIL=concierge@tableau.app

# Demo controls
DEMO_FIXTURE_REPLAY=true
TICK_INTERVAL_SECONDS=120

# API
API_BASE_URL=http://localhost:8000
INTERNAL_TICK_TOKEN=replace-me-with-cloud-scheduler-oidc

# Langfuse (optional but recommended for demo)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# Cost cap (USD) — soft limit shown in UI
DAILY_COST_CAP=5.00
